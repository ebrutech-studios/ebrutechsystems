rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == 'ebrutechstudios@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validProfileCreate(userId) {
      return owns(userId)
        && request.resource.data.keys().hasOnly([
          'email', 'displayName', 'photoURL', 'authCreatedAt',
          'lastSignInAt', 'lastSeenAt'
        ]);
    }

    function validProfileUpdate(userId) {
      return owns(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email', 'displayName', 'photoURL', 'authCreatedAt',
          'lastSignInAt', 'lastSeenAt'
        ]);
    }

    match /users/{userId} {
      allow read: if owns(userId) || isAdmin();
      allow create: if validProfileCreate(userId) || isAdmin();
      allow update: if validProfileUpdate(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /adminAudit/{entryId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /toolReviews/{toolId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5;
      allow update, delete: if false;
    }

    // ===== Filo Takip (filo.ebrutechsystems.com) =====
    function isFiloSurucu() {
      return signedIn() && exists(/databases/$(database)/documents/filo_surucular/$(request.auth.uid));
    }

    match /filo_surucular/{uid} {
      allow read: if isAdmin() || owns(uid);
      allow write: if isAdmin();
    }

    match /filo_araclar/{aracId} {
      allow read: if isAdmin() || (isFiloSurucu() && resource.data.surucuUid == request.auth.uid);
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isFiloSurucu()
            && resource.data.surucuUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sonKonum', 'durum']));

      match /gecmis/{entryId} {
        allow read: if isAdmin()
          || (isFiloSurucu() && get(/databases/$(database)/documents/filo_araclar/$(aracId)).data.surucuUid == request.auth.uid);
        allow create: if isAdmin()
          || (isFiloSurucu()
              && get(/databases/$(database)/documents/filo_araclar/$(aracId)).data.surucuUid == request.auth.uid);
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
